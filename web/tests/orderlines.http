### Opret en ny ordrelinie
POST http://localhost:3300/api/orders
Content-Type: application/json

{
  "orderdate" : "2020-07-01",
  "invoice" : 301,
  "shipby" : "PostNord",
  "paymethod" : "AMEX",
  "user_id" : 18,
  "lines" : [
    {
      "book_id" : 45,
      "numbooks" : 9
    }]
}

> {% client.test("Request executed successfully", function() {
     client.assert(response.status === 201, "Response status is not 201")
     client.global.set('order',response.body.data.order.id)
     client.log('Den nye ordre...', response.body.data.order.id)
  })
  %}


### Add an orderline book 46
POST http://localhost:3300/api/orderlines
Content-Type: application/json

{
  "order_id": {{ order }},
  "book_id": 46,
  "numbooks": 3
}

> {% client.test("Request executed successfully", function() {
     client.assert(response.status === 201, "Response status is not 201")
     })
  %}

### fail to add orderline again book 46
POST http://localhost:3300/api/orderlines
Content-Type: application/json

{
  "order_id": {{ order }},
  "book_id": 46,
  "numbooks": 3
}

> {% client.test("Request executed successfully", function() {
  const description = "Der findes allerede en ordrelinje for bog nummer 46"
     client.assert(response.status === 400, "Response status is not 400")
     console.log(response.body)
     client.assert(response.body.error.description[0] === description, 'Response er ikke at bogen allerede findes')
     })
  %}

### add orderline book 45
PUT http://localhost:3300/api/orderlines
Content-Type: application/json

{
  "order_id": {{order}},
  "book_id": 45,
  "numbooks": 4
}

> {% client.test("Request executed successfully", function() {
     client.assert(response.status === 201, "Response status is not 201")
     })
  %}


### delete orderline book 46
DELETE http://localhost:3300/api/orderlines/{{ order }}/book/46

> {% client.test("Request executed successfully", function() {
     client.assert(response.status === 200, "Response status is not 200")
     })
  %}

